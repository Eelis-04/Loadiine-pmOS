				<div id="mw-content-text" class="mw-body-content"><div class="mw-content-ltr mw-parser-output" lang="en-GB" dir="ltr"><section class="citizen-section" id="citizen-section-0"><div id="Ads-InfoboxTop"></div><table class="infobox"><tbody><tr><th class="infobox-title" scope="col" colspan="2">Loadiine GX2</th></tr><tr><td class="infobox-image" colspan="2"><span typeof="mw:File"><a href="/wiki/File:Loadiinegx2wiiu.png" class="mw-file-description"><img src="/thumb.php?f=Loadiinegx2wiiu.png&amp;width=300" decoding="async" loading="lazy" width="300" height="169" class="mw-file-element" srcset="/thumb.php?f=Loadiinegx2wiiu.png&amp;width=450 1.5x, /thumb.php?f=Loadiinegx2wiiu.png&amp;width=600 2x"></a></span></td></tr><tr><th class="infobox-header" scope="col" colspan="2"><div id="largemobilebanner"></div></th></tr><tr><th class="infobox-header" scope="col" colspan="2">General</th></tr><tr><th scope="row" class="infobox-label">Author</th><td class="infobox-data">Dimok, Cyan, Maschell, n1ghty, dibas</td></tr><tr><th scope="row" class="infobox-label">Type</th><td class="infobox-data"><a href="/index.php?title=List_of_WiiU_homebrew_applications&amp;action=edit&amp;redlink=1" class="new" title="List of WiiU homebrew applications (page does not exist)">Title Launchers</a>  </td></tr><tr><th scope="row" class="infobox-label">Version</th><td class="infobox-data">0.3</td></tr><tr><th scope="row" class="infobox-label">License</th><td class="infobox-data">GPL-3.0</td></tr><tr><th scope="row" class="infobox-label">Last Updated</th><td class="infobox-data">2017/10/15</td></tr><tr><th class="infobox-header" scope="col" colspan="2"><div id="Ads-Infobox1"></div></th></tr><tr><th class="infobox-header" scope="col" colspan="2">Links</th></tr><tr><td class="infobox-data" colspan="2" style="text-align:center"><a rel="nofollow" class="external text" href="https://dlhb.gamebrew.org/wiiuhomebrews/loadiinegx2wiiu.7z">Download</a></td></tr><tr><td class="infobox-data" colspan="2" style="text-align:center"><a rel="nofollow" class="external text" href="https://gbatemp.net/threads/loadiine-gx2.413823/">Website</a></td></tr><tr><td class="infobox-data" colspan="2" style="text-align:center"><a rel="nofollow" class="external text" href="https://github.com/dimok789/loadiine_gx2">Source</a></td></tr><tr><th class="infobox-header" scope="col" colspan="2"><div id="Ads-Infobox"></div></th></tr></tbody></table>
